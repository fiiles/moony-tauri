# Environment Variables Example
# Copy this file to .env and fill in your values

# ============================================================================
# Optional: Development Settings
# ============================================================================

# Enable debug mode for additional logging (default: false)
# VITE_DEBUG_MODE=true

# ============================================================================
# Analytics (Build-time — injected at compile time, not stored in DB)
# ============================================================================

# Aptabase analytics key — only needed if you run your own Aptabase instance.
# Leave unset to build without analytics support.
# VITE_APTABASE_KEY=your_aptabase_key_here